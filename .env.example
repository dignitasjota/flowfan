# Database
POSTGRES_USER=fanflow
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=fanflow
DATABASE_URL=postgresql://fanflow:change-this-password@localhost:5432/fanflow

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# Encryption key for API keys at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# AI API keys are now configured per-creator in the app settings UI

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=FlowFan <noreply@flowfan.app>

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=your-org
SENTRY_PROJECT=fanflow

# App base URL (used as redirect_uri for OAuth flows)
APP_URL=http://localhost:3000

# Twitter / X OAuth 2.0 (developer.x.com → OAuth 2.0 client)
# Scopes used: tweet.read, tweet.write, users.read, offline.access
# Redirect URI to register: {APP_URL}/api/oauth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Twitter / X filtered stream (OPTIONAL — opt-in to real-time comments).
# App-only bearer token from developer.x.com → Keys and tokens. When set,
# a persistent worker connects to /2/tweets/search/stream and ingests
# replies in real time. The 5-min poller stays active as fallback.
# Free tier: up to 1000 rules and ~500K tweets/month.
TWITTER_BEARER_TOKEN=

# Facebook Login for Instagram Graph API (developers.facebook.com)
# Requires Instagram Business/Creator account linked to a Facebook Page.
# Scopes: pages_show_list, pages_read_engagement, instagram_basic, instagram_content_publish
# Redirect URI to register: {APP_URL}/api/oauth/instagram/callback
FB_CLIENT_ID=
FB_CLIENT_SECRET=

# Instagram webhooks (Meta → /api/webhooks/instagram)
# Webhook callback URL: {APP_URL}/api/webhooks/instagram
# Subscribe to "comments" field on the Instagram product in the FB app dashboard.
# VERIFY_TOKEN: any random string; must match what you put in the dashboard.
# APP_SECRET: from the FB app "Basic" settings — used to validate X-Hub-Signature-256.
META_WEBHOOK_VERIFY_TOKEN=
META_WEBHOOK_APP_SECRET=

# Cloudflare R2 / S3-compatible storage (OPTIONAL — fallback to local FS).
# When all five vars are set, uploaded media (images, GIFs, videos) lands in
# R2 and the public URL is used by Reddit / Instagram / Twitter publishers
# (they fetch the asset server-side, so the URL must be reachable without
# auth). See src/server/services/r2-storage.ts.
#
# R2_ENDPOINT      — https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET        — bucket name
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY — from R2 dashboard → API tokens
# R2_PUBLIC_URL    — public base URL: https://pub-<hash>.r2.dev or a custom
#                    domain in front of the bucket. Used to build the URL
#                    returned to clients and to platform fetchers.
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=
